      <aliases enabled='yes' />
      <column caption='Ideal capacity percent' datatype='real' default-format='p0.00%' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(ZN(SUM([Pivot Field Values])) - LOOKUP(ZN(SUM([Pivot Field Values])), -1)) / ABS(LOOKUP(ZN(SUM([Pivot Field Values])), -1))'>
          <table-calc ordering-type='Columns' />
        </calculation>
      </column>
      <column caption='Moving average ideal capacity' datatype='real' name='[Calculation_1057783007586349057]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if(WINDOW_COUNT([Calculation_1347702233403940864],-7,0)-8)&#13;&#10;THEN(WINDOW_AVG([Calculation_1347702233403940864],-7,0)&#13;&#10;ELSE NULL&#13;&#10;END' />
      </column>
      <column caption='Positve ideal capacity percent' datatype='real' name='[Calculation_1347702233403940864]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='-1*(ZN(SUM([Pivot Field Values])) - LOOKUP(ZN(SUM([Pivot Field Values])), -1)) / ABS(LOOKUP(ZN(SUM([Pivot Field Values])), -1))'>
          <table-calc ordering-field='[federated.0cstajw0xmr3ht15oibru01xytcj].[Datetime (RL1)]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='Table calc' datatype='real' name='[Calculation_1347702233409708033]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_AVG(SUM([Pivot Field Values]),-2,0)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='moving average' datatype='real' name='[Calculation_1347702233412427779]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_AVG([Calculation_1347702233403940864],-7,0)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
