    <worksheet name='Sheet 1'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#ff0000' fontname='Bodoni MT Black' fontsize='16'>CRIM    : Per capita crime rate by town  </run>
            <run>Æ&#10;</run>
            <run fontcolor='#ff0000' fontname='Bodoni MT Black' fontsize='16'>ZN      : Proportion of residential land zoned for lots over 25,000 sq.ft.  </run>
            <run>Æ&#10;</run>
            <run fontcolor='#ff0000' fontname='Bodoni MT Black' fontsize='16'>INDUS   : Proportion of non-retail business acres per town  </run>
            <run>Æ&#10;</run>
            <run fontcolor='#ff0000' fontname='Bodoni MT Black' fontsize='16'>CHAS    : Charles River dummy variable (= 1 if tract bounds river; 0 otherwise)  </run>
            <run>Æ&#10;</run>
            <run fontcolor='#ff0000' fontname='Bodoni MT Black' fontsize='16'>NOX     : Nitric oxides concentration (parts per 10 million)  </run>
            <run>Æ&#10;</run>
            <run fontcolor='#ff0000' fontname='Bodoni MT Black' fontsize='16'>RM      : Average number of rooms per dwelling  </run>
            <run>Æ&#10;</run>
            <run fontcolor='#ff0000' fontname='Bodoni MT Black' fontsize='16'>AGE     : Proportion of owner-occupied units built prior to 1940  </run>
            <run>Æ&#10;</run>
            <run fontcolor='#ff0000' fontname='Bodoni MT Black' fontsize='16'>DIS     : Weighted distances to five Boston employment centres  </run>
            <run>Æ&#10;</run>
            <run fontcolor='#ff0000' fontname='Bodoni MT Black' fontsize='16'>RAD     : Index of accessibility to radial highways  </run>
            <run>Æ&#10;</run>
            <run fontcolor='#ff0000' fontname='Bodoni MT Black' fontsize='16'>TAX     : Full-value property-tax rate per $10,000  </run>
            <run>Æ&#10;</run>
            <run fontcolor='#ff0000' fontname='Bodoni MT Black' fontsize='16'>PTRATIO : Pupil-teacher ratio by town  </run>
            <run>Æ&#10;</run>
            <run fontcolor='#ff0000' fontname='Bodoni MT Black' fontsize='16'>B       : 1000(Bk - 0.63)^2 where Bk is the proportion of blacks by town  </run>
            <run>Æ&#10;</run>
            <run fontcolor='#ff0000' fontname='Bodoni MT Black' fontsize='16'>LSTAT   : % lower status of the population  </run>
            <run>Æ&#10;</run>
            <run fontcolor='#ff0000' fontname='Bodoni MT Black' fontsize='16'>MEDV    : Median value of owner-occupied homes in $1000&apos;s</run>
            <run>Æ&#10;&#10;</run>
            <run fontcolor='#ff0000' fontname='Bodoni MT Black' fontsize='16'>￼        </run>
          </formatted-text>
        </title>
